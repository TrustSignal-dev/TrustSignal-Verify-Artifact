{
  "name": "trustsignal-verify-artifact",
  "version": "0.2.1",
  "description": "GitHub Action for verifying build artifacts with TrustSignal and capturing signed verification receipts.",
  "main": "dist/index.js",
  "type": "commonjs",
  "files": [
    "action.yml",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "ncc build src/index.js -o dist --minify --no-cache",
    "package": "npm run build",
    "check": "node --check src/index.js",
    "test:hygiene": "npm run build && node scripts/test-hygiene.js",
    "test:local": "npm run build && node scripts/test-local.js",
    "validate:dist:ci": "npm run build && git diff --exit-code -- dist/index.js",
    "validate:local": "npm run check && npm run test:hygiene && npm run test:local"
  },
  "dependencies": {
    "@actions/artifact": "^2.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1"
  },
  "keywords": [
    "github-action",
    "trustsignal",
    "verification",
    "devsecops",
    "ci-cd",
    "supply-chain",
    "artifact",
    "provenance",
    "compliance"
  ],
  "author": "TrustSignal",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
